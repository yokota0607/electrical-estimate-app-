# Neon PostgreSQL 接続URL（Neonダッシュボード → Connection Details → Connection string）
DATABASE_URL=

# Vercel Blob（Vercelダッシュボード → Storage → Blob → .env.localタブからコピー）
BLOB_READ_WRITE_TOKEN=

# Anthropic Claude API キー
ANTHROPIC_API_KEY=

# セッション署名キー（任意の長いランダム文字列）
AUTH_SECRET=change-me-to-a-long-random-secret
